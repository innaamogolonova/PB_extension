{
  "name": "function-annotations",
  "displayName": "Function Annotations",
  "description": "Mock up with CodeLens",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "functionAnnotations.showAnnotation",
        "title": "Show Function Annotation"
      }
    ],
    "configuration": {
      "title": "Function Annotations",
      "properties": {
        "functionAnnotations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable function annotations"
        },
        "functionAnnotations.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key for generating function annotations"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "marked": "^17.0.2",
    "openai": "^6.21.0"
  }
}
