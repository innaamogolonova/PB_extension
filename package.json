{
  "name": "pb_extension",
  "displayName": "PB Extension",
  "description": "Execute files and track runtime values at each line, filter with LLM",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pbExtension.executeFile",
        "title": "Execute File"
      },
      {
        "command": "pbExtension.testDebugExecutor",
        "title": "Test Debug Executor"
      },
      {
        "command": "pbExtension.toggleLLMFilter",
        "title": "PB: Toggle LLM Filter"
      },
      {
        "command": "pbExtension.showFullTrace",
        "title": "PB: Show Full Trace"
      }
    ],
    "configuration": {
      "title": "PB Extension",
      "properties": {
        "pbExtension.enabled": {
          "type": "boolean",
          "default": true
        },
        "pbExtension.openaiApiKey": {
          "type": "string",
          "default": ""
        },
        "pbExtension.llmFilteringEnabled": {
          "type": "boolean",
          "default": true
        }
      }
    }
  },
  "menus": {
    "editor/context": [
      {
        "command": "pbExtension.executeFile",
        "when": "editorTextFocus"
      }
    ]
  },
  
  "keybindings": [
    {
      "command": "pbExtension.executeFile",
      "key": "ctrl+shift+t",
      "mac": "cmd+shift+t",
      "when": "editorTextFocus"
    }
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "openai": "^6.21.0"
  }
}
